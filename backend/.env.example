# CodePilot Environment Variables
# Copy this file to .env and fill in your API keys

# Database
DATABASE_URL=postgresql://codepilot:codepilot@localhost:5432/codepilot

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM Configuration
LLM_MODE=groq_only  # hybrid | gemini_only | groq_only

# Groq API (for documentation generation)
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# OpenRouter (fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama:7b

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
MODEL_CACHE_DIR=/tmp/codepilot_models/all-MiniLM-L6-v2

# Sandbox Configuration
SANDBOX_TIMEOUT=120
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# Cache Configuration
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Security
SECRETS_SCAN_ENABLED=true

# CORS
CORS_ORIGINS=*

# Server
PORT=8000

